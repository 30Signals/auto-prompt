{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Company Legal Risk Replay Labeling Schema V2",
  "type": "object",
  "required": ["cases"],
  "properties": {
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "company_name",
          "timestamp",
          "query_log",
          "retrieved_results",
          "model_output",
          "labels"
        ],
        "properties": {
          "company_name": {"type": "string"},
          "timestamp": {"type": "string"},
          "query_log": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["query", "status", "hits"],
              "properties": {
                "query": {"type": "string"},
                "status": {"type": "string"},
                "hits": {"type": "number"},
                "error": {"type": "string"}
              }
            }
          },
          "retrieved_results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title", "content", "source", "url"],
              "properties": {
                "title": {"type": "string"},
                "content": {"type": "string"},
                "source": {"type": "string"},
                "url": {"type": "string"}
              }
            }
          },
          "model_output": {
            "type": "object",
            "required": ["risk_level", "should_work_with_company", "summary", "key_findings"],
            "properties": {
              "risk_level": {"type": "string"},
              "should_work_with_company": {"type": "string"},
              "summary": {"type": "string"},
              "key_findings": {"type": "string"}
            }
          },
          "labels": {
            "type": "object",
            "required": ["risk_level", "should_work_with_company", "key_findings"],
            "properties": {
              "risk_level": {
                "type": "string",
                "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL", ""]
              },
              "should_work_with_company": {
                "type": "string",
                "enum": ["YES", "NO", ""]
              },
              "key_findings": {
                "type": "array",
                "minItems": 0,
                "maxItems": 5,
                "items": {"type": "string"}
              },
              "risk_dimensions": {
                "type": "object",
                "properties": {
                  "regulatory_enforcement": {"$ref": "#/$defs/risk_dimension"},
                  "litigation_exposure": {"$ref": "#/$defs/risk_dimension"},
                  "fraud_corruption": {"$ref": "#/$defs/risk_dimension"},
                  "data_privacy_cybersecurity": {"$ref": "#/$defs/risk_dimension"},
                  "labor_employment": {"$ref": "#/$defs/risk_dimension"},
                  "environmental_safety": {"$ref": "#/$defs/risk_dimension"},
                  "sanctions_trade": {"$ref": "#/$defs/risk_dimension"},
                  "governance_ethics": {"$ref": "#/$defs/risk_dimension"}
                },
                "additionalProperties": false
              },
              "retrieval_quality": {
                "type": "object",
                "properties": {
                  "source_credibility": {"$ref": "#/$defs/nullable_score"},
                  "relevance": {"$ref": "#/$defs/nullable_score"},
                  "recency": {"$ref": "#/$defs/nullable_score"}
                },
                "additionalProperties": false
              },
              "reviewer_notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "nullable_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "risk_dimension": {
      "type": "object",
      "properties": {
        "severity": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 3
        },
        "confidence": {"$ref": "#/$defs/nullable_score"},
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
